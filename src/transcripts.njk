---
layout: layouts/base.njk
pagination:
  data: episodesWithTranscripts
  size: 1
  alias: episode
permalink: "{{ episode.transcriptPermalink }}"
eleventyComputed:
  title: "Transcript: {{ episode.title }}"
  description: "Full transcript of episode {{ episode.number }}: {{ episode.title }}."
---
<article class="transcript" data-pagefind-body>
  <header class="transcript__header">
    <p class="eyebrow"><span class="dots" aria-hidden="true"><i></i><i></i><i></i></span> Transcript · Episode {{ episode.number }}</p>
    <h1 class="transcript__title">{{ episode.title }}</h1>
    <p class="transcript__meta">
      {{ episode.publishDate | readableDate }}
      {% if episode.durationSeconds %} · {{ episode.durationSeconds | friendlyDuration }}{% endif %}
    </p>
    <p><a class="link-button" href="{{ episode.permalink }}">← Back to the episode</a></p>
  </header>

  <div class="prose transcript__body">
    {{ episode.transcriptText | paragraphs | safe }}
  </div>

  <footer class="transcript__footer">
    <p><a class="link-button" href="{{ episode.permalink }}">← Back to the episode</a></p>
  </footer>
</article>
