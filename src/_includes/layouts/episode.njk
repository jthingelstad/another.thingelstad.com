---
layout: layouts/base.njk
ogType: article
---
<article class="episode" data-pagefind-body>
  <header class="episode__header">
    <p class="episode__eyebrow">
      <span class="dots" aria-hidden="true"><i></i><i></i><i></i></span>
      Episode {{ episode.number }} · {{ episode.publishDate | readableDate }}{% if episode.durationSeconds %} · {{ episode.durationSeconds | friendlyDuration }}{% endif %}
    </p>
    <h1 class="episode__title">{{ episode.title }}</h1>
    {% if episode.summary %}<p class="episode__summary">{{ episode.summary }}</p>{% endif %}
  </header>

  {% include "partials/player.njk" %}

  {% if episode.notesMarkdown %}
    <section class="episode__notes prose">
      {{ episode.notesMarkdown | renderMarkdown | safe }}
    </section>
  {% endif %}

  <aside class="episode__aside">
    {% if episode.transcriptText %}
      <a class="link-button" href="#transcript">Jump to transcript</a>
    {% endif %}
    <a class="link-button" href="/subscribe/">Subscribe</a>
    <button type="button" class="tinylytics_kudos" aria-label="Send kudos for this episode"></button>
  </aside>

  {% if episode.transcriptText %}
    <section id="transcript" class="episode__transcript">
      <header class="episode__transcript-header">
        <p class="eyebrow"><span class="dots" aria-hidden="true"><i></i><i></i><i></i></span> Transcript</p>
        <h2 class="episode__transcript-title">Transcript</h2>
      </header>
      <div class="prose episode__transcript-body">
        {{ episode.transcriptText | paragraphs | safe }}
      </div>
    </section>
  {% endif %}
</article>
